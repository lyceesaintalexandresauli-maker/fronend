# Supabase (override defaults in src/supabase.js if needed)
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=

# Canonical public URL of this frontend (no trailing slash). Used for Supabase
# signup confirmation emails (emailRedirectTo). Set in production to e.g.
# https://www.lyceemuhura.rw — must be listed under Supabase → Authentication
# → URL Configuration → Redirect URLs.
# VITE_PUBLIC_SITE_URL=https://www.lyceemuhura.rw
