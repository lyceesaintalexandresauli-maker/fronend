# Copy to .env and fill in real values. Vite only exposes variables prefixed with VITE_.
# Production: set these in your host (e.g. Render) before `npm run build`.

# --- Supabase (browser auth; required for login / student signup) ---
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_or_publishable_key_here
# VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key_here

# --- Backend API (REQUIRED when frontend and backend are on different domains) ---
# For separate deployments, uncomment and set to your backend URL
# Local development: http://localhost:5000
# Production: https://your-backend-domain.com
VITE_API_BASE_URL=https://your-backend-domain.com
VITE_ASSETS_BASE_URL=https://your-backend-domain.com

# --- Public site URL (SEO, Open Graph, Supabase email redirect; no trailing slash) ---
VITE_PUBLIC_SITE_URL=https://www.lyceemuhura.rw
VITE_SITE_URL=https://www.lyceemuhura.rw
